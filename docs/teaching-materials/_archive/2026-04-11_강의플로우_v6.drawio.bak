ion=-90;" parent="1" vertex="1"><mxGeometry x="1660" y="700" width="80" height="590" as="geometry"/></mxCell><mxCell id="emoBar4" value="&lt;b&gt;흡수&lt;/b&gt;" style="text;html=1;strokeColor=#7f8c8d;fillColor=#fff2cc;align=center;verticalAlign=middle;fontSize=9;rotation=-90;" parent="1" vertex="1"><mxGeometry x="1660" y="1480" width="80" height="100" as="geometry"/></mxCell><mxCell id="emoBar5" value="&lt;b&gt;신뢰&lt;/b&gt;" style="text;html=1;strokeColor=#7f8c8d;fillColor=#ffe6cc;align=center;verticalAlign=middle;fontSize=9;rotation=-90;" parent="1" vertex="1"><mxGeometry x="1660" y="1590" width="80" height="400" as="geometry"/></mxCell><mxCell id="emoBar6" value="&lt;b&gt;미래&lt;/b&gt;" style="text;html=1;strokeColor=#7f8c8d;fillColor=#e1d5e7;align=center;verticalAlign=middle;fontSize=9;rotation=-90;" parent="1" vertex="1"><mxGeometry x="1660" y="2000" width="80" height="250" as="geometry"/></mxCell><mxCell id="emoBar7" value="&lt;b&gt;실전&lt;/b&gt;" style="text;html=1;strokeColor=#7f8c8d;fillColor=#f8cecc;align=center;verticalAlign=middle;fontSize=9;rotation=-90;" parent="1" vertex="1"><mxGeometry x="1660" y="2260" width="80" height="230" as="geometry"/></mxCell><mxCell id="emoBar8" value="&lt;b&gt;행동&lt;/b&gt;" style="text;html=1;strokeColor=#7f8c8d;fillColor=#d5e8d4;align=center;verticalAlign=middle;fontSize=9;rotation=-90;" parent="1" vertex="1"><mxGeometry x="1660" y="2500" width="80" height="280" as="geometry"/></mxCell><mxCell id="principle_banner" value="&lt;b&gt;&lt;font style=&quot;font-size:13px;&quot;&gt;3단계 투자 원칙 (강의 전체 관통)&lt;/font&gt;&lt;/b&gt;    1단계: Smart Money를 따라가라 (Follow)  |  2단계: 룰대로만 해라 (Rule)  |  3단계: 시스템으로 쌓아라 (Stack)" style="text;html=1;strokeColor=#2c3e50;fillColor=#2c3e50;fontColor=#ffffff;align=center;verticalAlign=middle;rounded=1;fontSize=12;" parent="1" vertex="1"><mxGeometry x="120" y="290" width="1500" height="50" as="geometry"/></mxCell><mxCell id="q_s1" value="&lt;i&gt;&amp;quot;충분히 잘 살고 있다고 생각하시는 분?&amp;quot; — 첫 30초 Hook&lt;/i&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="400" y="255" width="500" height="20" as="geometry"/></mxCell><mxCell id="s1box" value="&lt;b&gt;&lt;font style=&quot;font-size:14px;&quot;&gt;SECTION 1 : Opening Hook — 세상이 빠르게 변하고 있다 (15분)&lt;/font&gt;&lt;/b&gt;  :  감정 — 공포/현실" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=12;" parent="1" vertex="1"><mxGeometry x="120" y="80" width="1500" height="200" as="geometry"/></mxCell><mxCell id="disc_s1" value="" style="shape=mxgraph.arrows2.arrow;fillColor=#FF0000;strokeColor=#CC0000;" parent="1" vertex="1" tooltip="면책"><mxGeometry x="1610" y="82" width="15" height="15" as="geometry"/></mxCell><mxCell id="s1_1" value="&lt;b&gt;1-1. 강남 비유 (3분)&lt;/b&gt;&lt;br&gt;&lt;i&gt;&amp;quot;충분히 잘 살고 있다고&lt;br&gt;생각하시는 분?&amp;quot;&lt;br&gt;(손들기 → 30초 Hook)&lt;/i&gt;&lt;br&gt;테헤란로 vs 뒷골목&lt;br&gt;50m = 30년 격차&lt;br&gt;&quot;괜찮은 게 아닙니다&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;" parent="1" vertex="1"><mxGeometry x="140" y="115" width="260" height="145" as="geometry"/></mxCell><mxCell id="s1_2" value="&lt;b&gt;1-2. 충격 통계 (4분)&lt;/b&gt;&lt;br&gt;850만 일자리 대체&lt;br&gt;43% AI 사용 / 56% 교육 0&lt;br&gt;연 50% 비용 절감" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;" parent="1" vertex="1"><mxGeometry x="415" y="115" width="260" height="120" as="geometry"/></mxCell><mxCell id="s1_3" value="&lt;b&gt;1-3. 마지막 기회 (4분)&lt;/b&gt;&lt;br&gt;AI 타임라인 2022-2027&lt;br&gt;엑셀 거부 회계사 = 실직&lt;br&gt;이중 트랙: 투자 + AI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;" parent="1" vertex="1"><mxGeometry x="690" y="115" width="260" height="120" as="geometry"/></mxCell><mxCell id="s1_4" value="&lt;b&gt;1-4. 역설 선언 (4분)&lt;/b&gt;&lt;br&gt;&quot;주식 강의가 중요한 게 아니다&quot;&lt;br&gt;이중 트랙 공개&lt;br&gt;오늘의 약속" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;" parent="1" vertex="1"><mxGeometry x="965" y="115" width="260" height="120" as="geometry"/></mxCell><mxCell id="s2box" value="&lt;b&gt;&lt;font style=&quot;font-size:14px;&quot;&gt;SECTION 2 : &quot;나는 이렇게 빡세게 산다&quot; — 개인 스토리 (20분)&lt;/font&gt;&lt;/b&gt;  :  감정 — 경외/공감" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=12;" parent="1" vertex="1"><mxGeometry x="120" y="310" width="1500" height="390" as="geometry"/></mxCell><mxCell id="s2_1_header" value="&lt;b&gt;2-1. 6가지 핵심 역할 공개 (5분)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;" parent="1" vertex="1"><mxGeometry x="140" y="330" width="300" height="20" as="geometry"/></mxCell><mxCell id="r1" value="&lt;b&gt;1. 교보그룹&lt;/b&gt;&lt;br&gt;디플래닉스 조직장&lt;br&gt;(임원)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" parent="1" vertex="1"><mxGeometry x="140" y="358" width="210" height="65" as="geometry"/></mxCell><mxCell id="r2" value="&lt;b&gt;2. 데이터 사업&lt;/b&gt;&lt;br&gt;기획자&lt;br&gt;KANDLE/AI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" parent="1" vertex="1"><mxGeometry x="360" y="358" width="210" height="65" as="geometry"/></mxCell><mxCell id="r3" value="&lt;b&gt;3. AI 컨설턴트&lt;/b&gt;&lt;br&gt;금융사 생성형AI&lt;br&gt;도입 자문" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" parent="1" vertex="1"><mxGeometry x="580" y="358" width="210" height="65" as="geometry"/></mxCell><mxCell id="r4" value="&lt;b&gt;4. 만화카페 사장&lt;/b&gt;&lt;br&gt;150평&lt;br&gt;book.frindle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" parent="1" vertex="1"><mxGeometry x="800" y="358" width="210" height="65" as="geometry"/></mxCell><mxCell id="r5" value="&lt;b&gt;5. 주식 강사&lt;/b&gt;&lt;br&gt;유튜브 112편&lt;br&gt;지금 이 순간" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" parent="1" vertex="1"><mxGeometry x="1020" y="358" width="210" height="65" as="geometry"/></mxCell><mxCell id="r6_more" value="&lt;b&gt;외 6개&lt;/b&gt;&lt;br&gt;쌍둥이 아빠 / 이직 준비생&lt;br&gt;경매 투자자 / 자판기 사업 등" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#82b366;fontStyle=2;" parent="1" vertex="1"><mxGeometry x="1240" y="358" width="350" height="65" as="geometry"/></mxCell><mxCell id="s2_2" value="&lt;b&gt;2-2. 비밀 공개 (5분)&lt;/b&gt;&lt;br&gt;Claude Code $200 x 4계정 = $800/월&lt;br&gt;멀티계정 심링크 공유&lt;br&gt;YouTube→LLM Wiki 파이프라인" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" parent="1" vertex="1"><mxGeometry x="140" y="445" width="500" height="100" as="geometry"/></mxCell><mxCell id="s2_3_header" value="&lt;b&gt;2-3. 충격 데모 5연발 (5분)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;" parent="1" vertex="1"><mxGeometry x="660" y="445" width="250" height="20" as="geometry"/></mxCell><mxCell id="d1" value="&lt;b&gt;D1: PLAUD&lt;/b&gt;&lt;br&gt;주 20건 회의록 자동" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" parent="1" vertex="1"><mxGeometry x="660" y="470" width="155" height="55" as="geometry"/></mxCell><mxCell id="d2" value="&lt;b&gt;D2: 주간보고&lt;/b&gt;&lt;br&gt;5개소스→3분" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" parent="1" vertex="1"><mxGeometry x="825" y="470" width="155" height="55" as="geometry"/></mxCell><mxCell id="d3" value="&lt;b&gt;D3: 500종목&lt;/b&gt;&lt;br&gt;42원/월 $13.50" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" parent="1" vertex="1"><mxGeometry x="990" y="470" width="155" height="55" as="geometry"/></mxCell><mxCell id="d4" value="&lt;b&gt;D4: 이 강의&lt;/b&gt;&lt;br&gt;8-agent 팀" style="rounded=1;white