                <mxCell id="title" value="US-Stock 배포 아키텍처 v3 — Next.js + git-scraping (book-finder 패턴)" style="text;html=1;align=center;fillColor=none;strokeColor=none;fontSize=18;fontStyle=1;fontColor=#1a237e;" vertex="1" parent="1">
